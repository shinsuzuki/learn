<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="internal-nlog-AspNetCore.txt">

	<!-- ログの出力先（Targets）の定義 -->
	<targets>
		<!-- 1. ファイルへの日別ローテーション出力 -->
		<target xsi:type="File" name="allfile"
				fileName="logs/app-${shortdate}.log"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />

		<!-- 2. コンソールへの色付き出力（開発環境の視認性向上） -->
		<target xsi:type="ColoredConsole" name="lifetimeConsole"
				layout="${longdate}|${level:uppercase=true}|${message} ${exception:format=tostring}" />
	</targets>

	<!-- ログの出力ルール（Rules） -->
	<rules>
		<!-- Microsoftの内部的な細かいログは無視し、Warning以上のみ出力 -->
		<logger name="Microsoft.*" maxlevel="Info" final="true" />
		<logger name="System.Net.Http.*" maxlevel="Info" final="true" />

		<!-- すべてのログをファイルとコンソールに出力 -->
		<logger name="*" minlevel="Info" writeTo="allfile,lifetimeConsole" />
	</rules>
</nlog>